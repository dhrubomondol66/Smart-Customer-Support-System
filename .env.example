# .env.example — copy this to .env and fill in values for local development
# DO NOT commit the actual .env file (it is in .gitignore)

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support_inbox

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
